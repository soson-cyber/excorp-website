# ── Notion 통합 (서버 전용, 최소 권한 분리) ─────────────────────
# ⚠️ 절대 NEXT_PUBLIC_ 접두사를 붙이지 말 것 (클라이언트 번들 노출 = 토큰 유출)
# 값 비우면 사이트는 하드코딩 fallback 데이터로 정상 동작한다.

# 1) 공개 콘텐츠 읽기 전용 Integration
#    NEWS/WORK/CAREER/INSIGHTS DB에만 Connect하고 읽기 권한만 부여한다.
NOTION_PUBLIC_TOKEN=

# 2) 문의 쓰기 전용 Integration
#    WEBSITE_INQUIRY DB에만 Connect하고 입력에 필요한 최소 권한만 부여한다.
NOTION_INQUIRY_TOKEN=

# 3) 데이터 소스 ID — 2026-06 MASTER DB/Website에 생성 완료(아래 값 그대로 사용).
#    (ID는 비밀 아님; 토큰 없이는 접근 불가. @notionhq/client v5는 data source id로 쿼리/생성)
NOTION_DS_NEWS=791df7ea-7c13-43ca-b672-df8cb78777f0
NOTION_DS_WORK=a4710578-c39a-4fed-b810-5ea23175c4b8
NOTION_DS_CAREER=6aa4cb41-9741-4d5c-9ad7-8e0f313a14e0
NOTION_DS_INSIGHTS=6fd85bb5-43a8-4e49-ace3-3b3640d59d6d
NOTION_DS_INQUIRY=0c82d66c-feaf-45e1-9128-ff1113619fbd

# ── (선택) 이메일 알림 — 가동 시 ──────────────────────────────────
# RESEND_API_KEY=

# ── (선택) Google Analytics 4 — 측정 ID(예: G-XXXXXXXXXX) ──────────
# 값을 비우면 분석 스크립트를 렌더하지 않는다(로컬·미연결 환경에서 안전).
# ⚠️ NEXT_PUBLIC_ 접두사는 클라이언트에 노출됨 — GA 측정 ID는 공개 값이므로 의도된 동작.
NEXT_PUBLIC_GA_ID=
